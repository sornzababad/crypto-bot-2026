# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#   nano .env

# ── BinanceTH API ─────────────────────────────────────────────
BINANCE_API_KEY=your_binance_th_api_key_here
BINANCE_API_SECRET=your_binance_th_api_secret_here

# ── LINE Notify (for trade alerts) ────────────────────────────
LINE_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here
